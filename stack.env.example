# PostgreSQL (service name in compose: db)
POSTGRES_USER=agro
POSTGRES_PASSWORD=agro
POSTGRES_DB=agro
POSTGRES_PORT=5432

# Built from POSTGRES_* above. Override only if db runs elsewhere.
DB_URL=postgresql+asyncpg://agro:agro@db:5432/agro

# Localhost URL for psql/migrations run from host
DB_URL_LOCAL=postgresql://agro:agro@localhost:5432/agro

# Logging
LOG_LEVEL=DEBUG

# Storage
VIDEOS_STORAGE=./data/videos
FAILED_VIDEOS_FOLDER=./data/failed_videos
QUEUES_ROOT=./data/queue

# Concurrency — bounds the ProcessPoolExecutor used by the ArUco
# worker. Each worker forks from the api process, so this value
# directly multiplies the memory footprint of the api container.
# Set to the number of physical cores (minus one for uvicorn) for
# the best throughput; lower it on memory-constrained hosts.
MAX_PROCESS_WORKERS=4

# Detector defaults
ARUCO_DICT=DICT_4X4_50
VELOCITY_PX_THRESHOLD=3.0

# Visit state machine
ENTRY_CONFIRM_SECONDS=1.0
EXIT_CONFIRM_SECONDS=10.0
STALE_CHECK_INTERVAL_SECONDS=5

# MQTT broker (eclipse-mosquitto). The api + mqtt_consumer + edge
# talk to it through the docker-network hostname `mqtt`.
MQTT_DOCKER_TAG=2.0
MQTT_PORT=1883
MQTT_BROKER_URL=mqtt://mqtt:1883
MQTT_CLIENT_ID=agro-tracking
MQTT_QOS=1
MQTT_KEEPALIVE=60
MQTT_RECONNECT_INITIAL_DELAY=1.0
MQTT_RECONNECT_MAX_DELAY=30.0
MQTT_DETECTION_TOPIC=farm/+/detections
# MQTT_USERNAME=  # uncomment for a production broker with auth
# MQTT_PASSWORD=  # uncomment for a production broker with auth
# MQTT_TLS_INSECURE=false  # only set true for self-signed lab brokers

# MQTT consumer (server-side forwarder). CONSUMER_API_URL points
# at the api service on the docker network.
CONSUMER_API_URL=http://api:8000
CONSUMER_INGEST_PATH=/v1/events/ingest
CONSUMER_REQUEST_TIMEOUT=10.0
CONSUMER_MAX_RETRIES=3
CONSUMER_RETRY_BACKOFF=1.0
CONSUMER_CLIENT_ID_PREFIX=agro-consumer

# Edge process (RTSP -> ArUco -> MQTT). The Pi-side deployment
# uses EDGE_RTSP_URL= to point at the local camera.
EDGE_RTSP_URL=rtsp://localhost:8554/cam
EDGE_STATION_CODE=STATION_EDGE
EDGE_FPS_TARGET=10.0
EDGE_FRAME_SKIP=1
EDGE_RECONNECT_DELAY=2.0
EDGE_PUBLISH_INTERVAL_SEC=5.0
EDGE_PUBLISH_MAX_EVENTS=500
# EDGE_ROI_POLYGON=[[x1,y1],[x2,y2],...]
EDGE_TOPIC_PREFIX=farm
